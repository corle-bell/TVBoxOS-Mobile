<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:id="@+id/topLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="200dp"
            android:text="@string/app_name"
            android:textColor="@color/text_foreground"
            android:textSize="@dimen/tv_title_text_size"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:background="@drawable/tv_item_focus_selector"
            android:padding="8dp" />

        <TextView
            android:id="@+id/search"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/bg_large_round_gray"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:hint="搜索"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:foreground="@drawable/tv_item_focus_selector" />

        <TextView
            android:id="@+id/iv_history"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="历史"
            android:textColor="@color/text_foreground"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:background="@drawable/tv_item_focus_selector" />

        <TextView
            android:id="@+id/iv_collect"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:text="收藏"
            android:textColor="@color/text_foreground"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:background="@drawable/tv_item_focus_selector" />
    </LinearLayout>

    <com.owen.tvrecyclerview.widget.TvRecyclerView
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingHorizontal="4dp"
        app:tv_selectedItemIsCentered="true" />

    <FrameLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp">

        <androidx.viewpager.widget.ViewPager
            android:id="@+id/mViewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

</LinearLayout>
